# ============================================
# 네이버 클라우드 플랫폼 (지도 표시용)
# ============================================
# https://console.ncloud.com/maps/application
# 1. 애플리케이션 등록 → Dynamic Map 선택 필수
# 2. Web 서비스 URL에 http://localhost:3000 등록 필수!
# 3. Client ID 복사

# 클라이언트용: 지도 표시 (NEXT_PUBLIC_ 이므로 브라우저에 노출됨)
# → 네이버 클라우드 플랫폼에서 발급한 Client ID
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=vydyity1hz

# ============================================
# 네이버 개발자 센터 (장소 검색용) ⚠️ 별도 등록 필요!
# ============================================
# https://developers.naver.com/apps/#/register
# 1. 애플리케이션 등록
# 2. 사용 API: "검색" 선택
# 3. 비로그인 오픈 API 서비스 환경: "Web" 선택
# 4. 서비스 URL: http://localhost:3000 등록
# 5. Client ID와 Client Secret 복사

# 서버용: 장소 검색·지오코딩 (API 라우트에서 사용, 노출 금지)
# → 네이버 개발자 센터에서 발급한 Client ID와 Client Secret
# ⚠️ 현재는 네이버 클라우드 플랫폼의 키가 들어가 있음 → 네이버 개발자 센터에서 발급받아야 함!
NAVER_CLIENT_ID=VJv9DUsvR7fSS3laGiIy
NAVER_CLIENT_SECRET=3ndJKq_C8y
