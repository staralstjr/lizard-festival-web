# MySQL 데이터베이스 연결 설정
# 사용법: .env.example을 .env로 복사하고 실제 값으로 변경하세요
# cp .env.example .env

DATABASE_URL=mysql+pymysql://username:password@localhost:3306/lizard_festival?charset=utf8mb4

# 예시:
# DATABASE_URL=mysql+pymysql://root:mypassword@localhost:3306/lizard_festival?charset=utf8mb4
# DATABASE_URL=mysql+pymysql://user:pass@192.168.1.100:3306/lizard_festival?charset=utf8mb4
